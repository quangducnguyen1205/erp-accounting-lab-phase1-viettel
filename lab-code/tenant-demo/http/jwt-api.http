# HTTP Client requests cho JWT tạm
# Chạy trong IntelliJ IDEA sau khi backend đang chạy.
#
# Flow chính hiện tại dùng Authorization: Bearer.
# Header X-Tenant-Id không còn được hỗ trợ vì JWT là mặc định.

# Dùng shared environment "development" trong http-client.private.env.json.
# accountantTenant1Token, viewerTenant2Token đã có sẵn.
@invalidJwt = invalid.jwt.token
@code = LAPTOP-01
@tenant2RecordId = 10

### Tạo/lấy dev token tenant 1
# Cần JWT_DEV_TOKEN_ENABLED=true trong .env.
# Tự động lấy token từ private env "development" nếu đã cấu hình.
# Sau khi chạy, 'accountantTenant1Token' sẽ được cập nhật trong global variables.
GET {{baseUrl}}/api/dev/tokens/tenant-1?roles=ACCOUNTANT

> {%
    client.global.set("accountantTenant1Token", response.body.accessToken);
    client.log("Updated global variable: accountantTenant1Token from dev endpoint");
%}

### Tạo/lấy dev token tenant 2
# Cần JWT_DEV_TOKEN_ENABLED=true trong .env.
# Sau khi chạy, 'viewerTenant2Token' sẽ được cập nhật trong global variables.
GET {{baseUrl}}/api/dev/tokens/tenant-2?roles=VIEWER

> {%
    client.global.set("viewerTenant2Token", response.body.accessToken);
    client.log("Updated global variable: viewerTenant2Token from dev endpoint");
%}

### JWT tenant 1 - list master data
# Expected sau khi JWT active: 200, chỉ thấy data tenant 1.
GET {{baseUrl}}/api/master-data
Authorization: Bearer {{accountantTenant1Token}}

### JWT tenant 2 - list master data
# Expected sau khi JWT active: 200, chỉ thấy data tenant 2.
GET {{baseUrl}}/api/master-data
Authorization: Bearer {{viewerTenant2Token}}

### Missing Authorization - expected 401 sau khi JWT active
GET {{baseUrl}}/api/master-data

### Invalid Authorization - expected 401 sau khi JWT active
GET {{baseUrl}}/api/master-data
Authorization: Bearer {{invalidJwt}}

### Query by code scoped theo tenant 1
GET {{baseUrl}}/api/master-data/code/{{code}}
Authorization: Bearer {{accountantTenant1Token}}

### Query by code scoped theo tenant 2
GET {{baseUrl}}/api/master-data/code/{{code}}
Authorization: Bearer {{viewerTenant2Token}}

### Cross-tenant id - tenant 1 gọi id của tenant 2
# Expected sau khi JWT active: 404 hoặc bị chặn, không lộ data tenant 2.
GET {{baseUrl}}/api/master-data/{{tenant2RecordId}}
Authorization: Bearer {{accountantTenant1Token}}
