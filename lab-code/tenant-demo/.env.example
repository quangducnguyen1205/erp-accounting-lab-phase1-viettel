# Ví dụ biến môi trường local cho tenant-demo.
# Copy thành `.env` nếu bạn muốn dùng local, nhưng không commit `.env`.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=erpdb
DB_USER=erpuser
DB_PASSWORD=erpuser
SERVER_PORT=8080

# Auth mode:
# - local-jwt: giữ flow JWT tạm hiện tại.
# - keycloak: dùng Keycloak-issued JWT từ mini-lab local.
APP_AUTH_MODE=local-jwt

# JWT tạm cho local learning.
# Đây KHÔNG phải password user và KHÔNG phải secret production.
# Khi tự implement JWT, copy sang `.env` và đổi secret local đủ dài.
JWT_SECRET=change-this-local-learning-secret-only
JWT_ISSUER=tenant-demo-local
JWT_EXPIRATION_SECONDS=3600
JWT_DEV_TOKEN_ENABLED=true

# Keycloak local mini-lab.
# KEYCLOAK_ISSUER_URI phải khớp claim `iss` trong token Keycloak.
# KEYCLOAK_CLIENT_ID là client chứa role claim trong resource_access.
# KEYCLOAK_JWK_SET_URI thường không cần set nếu dùng issuer-uri discovery.
KEYCLOAK_ISSUER_URI=http://localhost:18080/realms/viettel-lab
KEYCLOAK_CLIENT_ID=tenant-demo-api-client
KEYCLOAK_JWK_SET_URI=

# Elasticsearch/search mini-lab.
# Tắt mặc định để app/test không phụ thuộc Elasticsearch.
APP_SEARCH_ENABLED=false
ELASTICSEARCH_URIS=http://localhost:9200
ELASTICSEARCH_MASTER_DATA_INDEX=master_data_search

# MinIO/file storage mini-lab.
# Tắt mặc định để app/test không phụ thuộc MinIO.
# Dev credentials dưới đây khớp lab-code/minio-lab/docker-compose.yml.
# Không dùng các giá trị này cho production.
APP_FILE_STORAGE_ENABLED=false
MINIO_ENDPOINT=http://localhost:19000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tenant-demo-files
MINIO_REGION=us-east-1
